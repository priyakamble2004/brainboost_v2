# ─────────────────────────────────────────────────────────────
#  Brain Boost V2 — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your MySQL root password below
#  3. Never commit .env to git
# ─────────────────────────────────────────────────────────────

# MySQL connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=brainboost_v2

# Secret keys — change these to random strings in production
SECRET_KEY=brainboost_secret_key_change_this_in_production
JWT_SECRET_KEY=brainboost_jwt_key_change_this_in_production
